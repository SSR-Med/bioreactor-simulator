{
  "time": {
    "min": 0,
    "max": 72,
    "step": 0.1,
    "default": 72,
    "unit": "t",
    "axis_label": "t",
    "input_label": "Tiempo de simulaci\u00f3n"
  },
  "variables": {
    "X": {
      "label": "Biomasa X",
      "unit": "g/L",
      "description": "Concentraci\u00f3n de biomasa",
      "color": "#58a6ff"
    },
    "S": {
      "label": "Sustrato S",
      "unit": "g/L",
      "description": "Concentraci\u00f3n de sustrato",
      "color": "#3fb950"
    },
    "P": {
      "label": "Producto P",
      "unit": "g/L",
      "description": "Concentraci\u00f3n de producto",
      "color": "#f78166"
    },
    "V": {
      "label": "Volumen V",
      "unit": "m\u00b3",
      "description": "Volumen del biorreactor",
      "color": "#d2a8ff"
    }
  },
  "initial_conditions": {
    "X": { "value": 0.05, "label": "X(0)" },
    "S": { "value": 40.0, "label": "S(0)" },
    "P": { "value": 0.0, "label": "P(0)" },
    "V": { "value": 47.1, "label": "V(0)" }
  },
  "equations": {
    "V": "47.1 + 0.28 * t",
    "mu": "0.28 * S / (5 + S)",
    "dX_dt": "mu * X - (0.28 / (47.1 + 0.28 * t)) * X",
    "dS_dt": "(0.28 / (47.1 + 0.28 * t)) * (200 - S) - 2.478 * mu * X",
    "dP_dt": "1.436 * mu * X - (0.28 / (47.1 + 0.28 * t)) * P"
  }
}
